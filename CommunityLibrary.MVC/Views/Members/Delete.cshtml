@model MemberDeleteViewModel

@{
    ViewData["Title"] = "Delete Member";
}

<h1>Delete Member</h1>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="alert alert-danger">
    <strong>Are you sure you want to delete this member?</strong> This action cannot be undone.
</div>

@if (Model.ActiveLoanCount > 0)
{
    <div class="alert alert-warning">
        This member has <strong>@Model.ActiveLoanCount active loan(s)</strong> and cannot be deleted until all books are returned.
    </div>
}

<dl class="row col-md-5">
    <dt class="col-sm-4">Name</dt>
    <dd class="col-sm-8">@Model.FullName</dd>

    <dt class="col-sm-4">Active Loans</dt>
    <dd class="col-sm-8">@Model.ActiveLoanCount</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger" @(Model.ActiveLoanCount > 0 ? "disabled" : "")>
        Yes, Delete
    </button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>
