@model List<MemberSummaryViewModel>

@{
    ViewData["Title"] = "Members";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Members</h1>
    <a asp-action="Create" class="btn btn-primary">+ Register Member</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No members registered yet.</div>
}
else
{
    <table class="table table-hover table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Active Loans</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>@m.FullName</td>
                    <td>@m.Email</td>
                    <td class="text-muted">@m.Phone</td>
                    <td>
                        @if (m.ActiveLoanCount > 0)
                        {
                            <span class="badge text-bg-info">@m.ActiveLoanCount</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-action="Edit"    asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete"  asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted small">@Model.Count member(s) registered.</p>
}
