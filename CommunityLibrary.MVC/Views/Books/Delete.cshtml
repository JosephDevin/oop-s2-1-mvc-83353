@model BookDeleteViewModel

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="alert alert-danger">
    <strong>Are you sure you want to delete this book?</strong> This action cannot be undone.
</div>

@if (Model.HasActiveLoans)
{
    <div class="alert alert-warning">
        This book is currently on loan and cannot be deleted until it is returned.
    </div>
}

<dl class="row col-md-5">
    <dt class="col-sm-4">Title</dt>
    <dd class="col-sm-8">@Model.Title</dd>

    <dt class="col-sm-4">Author</dt>
    <dd class="col-sm-8">@Model.Author</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger" @(Model.HasActiveLoans ? "disabled" : "")>
        Yes, Delete
    </button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>
